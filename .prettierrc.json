{
  "plugins": ["prettier-plugin-twig-melody"],
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "printWidth": 80,
  "jsxSingleQuote": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "htmlWhitespaceSensitivity": "ignore",
  "endOfLine": "auto",
  "embeddedLanguageFormatting": "auto",
  "quoteProps": "as-needed",
  "arrowParens": "always",
  "proseWrap": "preserve",
  "singleAttributePerLine": true,
  "overrides": [
    {
      "files": ["*.njk"],
      "options": { "parser": "melody", "twigMelodyPreserveWhitespace": false }
    }
  ]
}
